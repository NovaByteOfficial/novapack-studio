{
  "name": "novapack-studio",
  "version": "1.1.31",
  "description": "NovaByte App Development Studio",
  "main": "index.html",
  "window": {
    "title": "NovaByte Studio",
    "width": 1280,
    "height": 800,
    "min_width": 900,
    "min_height": 600,
    "icon": "assets/icon.png",
    "frame": false,
    "show": true
  },
  "app": {
    "LSApplicationCategoryType": "public.app-category.developer-tools"
  },
  "chromium-args": "--disable-web-security --allow-file-access-from-files --disable-devtools --remote-debugging-port=0 --remote-allow-origins=none",
  "node-remote": "<all_urls>",
  "scripts": {
    "start": "nw .",
    "build": "node studio-inject.js && node build.mjs",
    "inject": "node studio-inject.js",
    "inject:watch": "node studio-inject.js --watch",
    "bundle:editor": "esbuild src/ui/editor.js --bundle --format=iife --global-name=_CMLoaded --external:typescript --external:@typescript/vfs --outfile=src/ui/editor.bundle.js"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.5",
    "@noble/ciphers": "^2.2.0",
    "@typescript/vfs": "^1.6.4",
    "@valtown/codemirror-ts": "^2.3.1",
    "codemirror": "6.0.2",
    "devicon": "^2.17.0",
    "dompurify": "^3.4.11",
    "marked": "^18.0.5",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "javascript-obfuscator": "5.4.3",
    "js-confuser": "^2.1.3",
    "nw": "^0.112.0",
    "nw-builder": "^4.17.11"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "nw-builder@4.17.11": true,
    "nw@0.112.0": true
  }
}
