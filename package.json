{
  "name": "novapack-studio",
  "version": "1.0.0",
  "description": "NovaByte App Development Studio",
  "main": "index.html",
  "window": {
    "title": "NovaByte Studio",
    "width": 1280,
    "height": 800,
    "min_width": 900,
    "min_height": 600,
    "icon": "assets/icon.png",
    "frame": false,
    "show": true
  },
  "app": {
    "LSApplicationCategoryType": "public.app-category.developer-tools"
  },
  "chromium-args": "--disable-web-security --allow-file-access-from-files",
  "node-remote": "<all_urls>",
  "scripts": {
    "start": "nw .",
    "build": "node studio-inject.js && node build.mjs",
    "inject": "node studio-inject.js",
    "inject:watch": "node studio-inject.js --watch",
    "bundle:editor": "esbuild src/ui/editor.js --bundle --format=iife --global-name=_CMLoaded --outfile=src/ui/editor.bundle.js"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.3",
    "codemirror": "6.0.2"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "javascript-obfuscator": "5.4.3",
    "nw": "^0.112.0-sdk",
    "nw-builder": "^4.17.11"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "nw@0.112.0": true,
    "nw-builder@4.17.11": true
  }
}
